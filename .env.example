# Optional: enables LLM highlight selection + post copy. Leave unset for offline heuristic mode.
ANTHROPIC_API_KEY=

# Whisper model: tiny | base | small | medium (bigger = better + slower on CPU)
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8

# Default clip knobs (overridable per job in the upload form)
DEFAULT_CLIP_COUNT=4
MIN_CLIP_SECONDS=20
MAX_CLIP_SECONDS=90

# Reject uploads larger than this many megabytes; tuned for Railway's 5 GB volume cap.
MAX_UPLOAD_MB=1024
UPLOAD_FREE_SPACE_RESERVE_MB=1536

# Concurrent ffmpeg renders (ffmpeg is itself multithreaded; keep low on a laptop)
RENDER_PARALLELISM=2
