# Optional: enables LLM highlight selection + post copy. Leave unset for offline heuristic mode.
ANTHROPIC_API_KEY=

# Whisper model: tiny | base | small | medium (bigger = better + slower on CPU)
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8

# Default clip knobs (overridable per job in the upload form)
DEFAULT_CLIP_COUNT=4
MIN_CLIP_SECONDS=20
MAX_CLIP_SECONDS=90
